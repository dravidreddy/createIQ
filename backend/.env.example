# CreateIQ Backend Environment Variables — Production Ready Template

# ─── Environment ────────────────────────────────────────────────
ENV=dev  # dev | test | prod
DEBUG=true
APP_NAME=CreateIQ

# ─── LLM Providers ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TOGETHER_API_KEY=your_together_api_key_here

# ─── Search Provider ─────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Database — MongoDB ──────────────────────────────────────────
# MONGO_URI is the connection string (Local or Atlas)
MONGO_URI=mongodb://localhost:27017/creatoriq_dev

# Advanced Connection Settings
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10
MONGODB_SERVER_TIMEOUT=5000
MONGODB_CONNECT_TIMEOUT=10000

# ─── Redis (Caching & Real-time) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Vector Store — Qdrant ───────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── JWT Authentication ──────────────────────────────────────────
SECRET_KEY=your_super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Cookie Security ─────────────────────────────────────────────
COOKIE_SECURE=false

# ─── Application Settings ────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# ─── V3.3 Adaptive Engine ───────────────────────────────────────
V3_3_ENABLED=false
LOAD_TEST_MODE=false

# Budget Enforcement (USD Cents)
BUDGET_DEFAULT_PER_JOB_CENTS=100
BUDGET_WARNING_THRESHOLD_CENTS=80
BUDGET_DAILY_USER_CAP_CENTS=500

# Tier Variant Caps
TIER_VARIANT_CAP_FREE=2
TIER_VARIANT_CAP_PRO=4
TIER_VARIANT_CAP_ENTERPRISE=5

# Evaluation & Ranking
EVAL_MAX_ITERATIONS=2
EVAL_QUALITY_THRESHOLD=0.85
RANKING_LEARNING_RATE=0.01

# State Management
STATE_MAX_SIZE_KB=200
STATE_RETENTION_DAYS=7

# SSE / Streaming (Alpha Readiness)
ALPHA_RATE_LIMIT_RPM=20
ALPHA_SSE_HISTORY_MAX=100
ALPHA_SSE_HISTORY_TTL=1800

# ─── Circuit Breaker & Timeouts ────────────────────────────────
CIRCUIT_BREAKER_ERROR_PCT=10.0
CIRCUIT_BREAKER_SAMPLE_SIZE=20
CIRCUIT_BREAKER_COOLDOWN_SEC=120

# Provider Specific Timeouts (Seconds)
TIMEOUT_GROQ=5.0
TIMEOUT_TOGETHER=10.0
TIMEOUT_OPENAI=15.0
TIMEOUT_CLAUDE=20.0
TIMEOUT_DEFAULT=30.0

# CB Thresholds (Failure count before trip)
CB_THRESHOLD_GROQ=3
CB_THRESHOLD_PREMIUM=7
CB_THRESHOLD_DEFAULT=5
